#!/usr/bin/env bash
set -euo pipefail

AGENTS_DIR="${CLAUDE_PROFILES_DIR:-$HOME/.agents}"
PROFILES_DIR="$AGENTS_DIR/profiles"
SHARED_DIR="$AGENTS_DIR/shared"
CLAUDE_DIR="${CLAUDE_DIR:-$HOME/.claude}"
CLAUDE_MD="$CLAUDE_DIR/CLAUDE.md"
CLAUDE_JSON="$HOME/.claude.json"
MCP_STATE="$AGENTS_DIR/.mcp-state.json"

# "profile-subdir:claude-subdir:item-type(file|dir)"
# file = symlink individual files; dir = symlink subdirectories (skills are folders)
ARTIFACTS=(
  "agents:agents:file"
  "rules:rules:file"
  "skills:skills:dir"
  "output-styles:output-styles:file"
  "workflows:workflows:file"
)

_bold()   { printf '\033[1m%s\033[0m' "$1"; }
_green()  { printf '\033[32m%s\033[0m' "$1"; }
_yellow() { printf '\033[33m%s\033[0m' "$1"; }
_red()    { printf '\033[31m%s\033[0m' "$1"; }

_profile_exists() { [ -d "$PROFILES_DIR/$1" ]; }

_current_profile() {
  if [ -L "$AGENTS_DIR/current" ]; then
    basename "$(readlink "$AGENTS_DIR/current")"
  else
    echo ""
  fi
}

# Remove symlinks in a claude subdir whose targets are inside our agents dir.
# We always create symlinks with absolute paths so a prefix check is sufficient.
_remove_managed_links() {
  local claude_subdir="$1"
  local target_dir="$CLAUDE_DIR/$claude_subdir"
  [ -d "$target_dir" ] || return 0
  find "$target_dir" -maxdepth 1 -type l | while read -r link; do
    local dest
    dest="$(readlink "$link")"
    if [[ "$dest" == "$AGENTS_DIR/"* ]]; then
      rm "$link"
    fi
  done
}

_link_artifacts() {
  local src_dir="$1" claude_subdir="$2" item_type="$3"
  [ -d "$src_dir" ] || return 0
  local target_dir="$CLAUDE_DIR/$claude_subdir"
  mkdir -p "$target_dir"
  if [ "$item_type" = "file" ]; then
    for item in "$src_dir"/*; do
      [ -f "$item" ] || continue
      local name; name="$(basename "$item")"
      ln -sfn "$item" "$target_dir/$name"
      echo "  + $claude_subdir/$name"
    done
  else
    # skills: link subdirectories (each contains SKILL.md)
    for item in "$src_dir"/*/; do
      [ -d "$item" ] || continue
      local name; name="$(basename "$item")"
      ln -sfn "$item" "$target_dir/$name"
      echo "  + $claude_subdir/$name/"
    done
  fi
}

# Patch ~/.claude.json mcpServers:
# - Remove servers we previously added (tracked in .mcp-state.json)
# - Inject shared + profile servers (profile wins on conflict)
# - Update state file so next switch knows what to remove
_patch_mcp() {
  local profile="$1"
  local profile_mcp="$PROFILES_DIR/$profile/mcp.json"
  local shared_mcp="$SHARED_DIR/mcp.json"

  [ -f "$CLAUDE_JSON" ] || { echo "  $(_yellow "~") MCP skipped — ~/.claude.json not found"; return 0; }

  if ! command -v jq &>/dev/null; then
    echo "  $(_yellow "~") MCP skipped — jq not installed (brew install jq / apt install jq)"
    return 0
  fi

  # Skip entirely if no state and no mcp.json to apply
  [ -f "$MCP_STATE" ] || [ -f "$profile_mcp" ] || [ -f "$shared_mcp" ] || return 0

  # Previously managed server names
  local prev_servers="[]"
  [ -f "$MCP_STATE" ] && prev_servers="$(jq '.managed_servers // []' "$MCP_STATE")"

  # Merge shared + profile servers (profile wins on conflict)
  local merged="{}"
  if [ -f "$shared_mcp" ]; then
    local shared_servers; shared_servers="$(jq '.mcpServers // {}' "$shared_mcp")"
    merged="$(jq -n --argjson a "$merged" --argjson b "$shared_servers" '$a * $b')"
  fi
  if [ -f "$profile_mcp" ]; then
    local profile_servers; profile_servers="$(jq '.mcpServers // {}' "$profile_mcp")"
    merged="$(jq -n --argjson a "$merged" --argjson b "$profile_servers" '$a * $b')"
  fi

  local new_names
  new_names="$(jq -n --argjson m "$merged" '$m | keys')"

  # Patch: remove previously managed, add new
  local tmp; tmp="$(mktemp)"
  jq --argjson prev "$prev_servers" \
     --argjson new_servers "$merged" \
     '.mcpServers = ((.mcpServers // {}) | with_entries(select(.key as $k | ($prev | index($k)) == null))) * $new_servers' \
     "$CLAUDE_JSON" > "$tmp" && mv "$tmp" "$CLAUDE_JSON"

  # Save state
  printf '{"profile":"%s","managed_servers":%s}\n' "$profile" "$new_names" > "$MCP_STATE"

  # Report
  if [ "$(jq 'length' <<< "$merged")" -gt 0 ]; then
    jq -r 'keys[]' <<< "$merged" | while read -r name; do
      echo "  + mcp/$name"
    done
  fi
}

cmd_use() {
  local profile="${1:-}"
  [ -n "$profile" ] || { echo "Usage: claude-profiles use <name>"; exit 1; }
  _profile_exists "$profile" || { echo "$(_red "Profile not found:") $profile"; exit 1; }
  local profile_dir="$PROFILES_DIR/$profile"

  # Remove all managed symlinks across every artifact dir
  for artifact in "${ARTIFACTS[@]}"; do
    IFS=: read -r _pdir claude_subdir _type <<< "$artifact"
    _remove_managed_links "$claude_subdir"
  done

  # Remove managed CLAUDE.md symlink
  if [ -L "$CLAUDE_MD" ]; then
    local dest; dest="$(readlink "$CLAUDE_MD")"
    if [[ "$dest" == "$AGENTS_DIR/"* ]]; then
      rm "$CLAUDE_MD"
    fi
  fi

  # Link shared artifacts first; profile overrides on name conflict
  for artifact in "${ARTIFACTS[@]}"; do
    IFS=: read -r pdir claude_subdir type <<< "$artifact"
    _link_artifacts "$SHARED_DIR/$pdir" "$claude_subdir" "$type"
  done

  # Link profile artifacts
  for artifact in "${ARTIFACTS[@]}"; do
    IFS=: read -r pdir claude_subdir type <<< "$artifact"
    _link_artifacts "$profile_dir/$pdir" "$claude_subdir" "$type"
  done

  # Switch current symlink
  ln -sfn "$profile_dir" "$AGENTS_DIR/current"

  # Link CLAUDE.md if profile has one
  if [ -f "$profile_dir/CLAUDE.md" ]; then
    if [ -f "$CLAUDE_MD" ] && [ ! -L "$CLAUDE_MD" ]; then
      mv "$CLAUDE_MD" "${CLAUDE_MD}.bak"
      echo "  $(_yellow "backed up") CLAUDE.md → CLAUDE.md.bak"
    fi
    ln -sfn "$profile_dir/CLAUDE.md" "$CLAUDE_MD"
    echo "  + CLAUDE.md → $profile"
  fi

  # Patch MCP servers in ~/.claude.json
  _patch_mcp "$profile"

  echo ""
  echo "$(_green "→") $(_bold "$profile")"
}

cmd_init() {
  local profile="${1:-}"
  [ -n "$profile" ] || { echo "Usage: claude-profiles init <name>"; exit 1; }
  _profile_exists "$profile" && { echo "$(_red "Already exists:") $profile"; exit 1; }
  local profile_dir="$PROFILES_DIR/$profile"
  mkdir -p "$profile_dir"/{agents,rules,skills,output-styles,workflows}
  cat > "$profile_dir/CLAUDE.md" <<EOF
# $profile

<!-- Instructions for this profile. Linked to ~/.claude/CLAUDE.md when active. -->
EOF
  cat > "$profile_dir/mcp.json" <<'EOF'
{
  "mcpServers": {}
}
EOF
  echo "$(_green "Created:") $(_bold "$profile")"
  echo "  $profile_dir"
  echo ""
  echo "  agents/        .md files    → ~/.claude/agents/"
  echo "  rules/         .md files    → ~/.claude/rules/"
  echo "  skills/        folders      → ~/.claude/skills/<name>/SKILL.md"
  echo "  output-styles/ .md files    → ~/.claude/output-styles/"
  echo "  workflows/     .js files    → ~/.claude/workflows/"
  echo "  mcp.json       servers      → ~/.claude.json mcpServers (requires jq)"
  echo ""
  echo "  claude-profiles use $profile"
}

cmd_list() {
  local current; current="$(_current_profile)"
  [ -d "$PROFILES_DIR" ] || { echo "No profiles at $PROFILES_DIR"; exit 1; }
  echo "$(_bold "Profiles")"
  echo ""
  local found=0
  for dir in "$PROFILES_DIR"/*/; do
    [ -d "$dir" ] || continue
    found=1
    local name; name="$(basename "$dir")"
    if [ "$name" = "$current" ]; then
      printf "  %s %s\n" "$(_green "→")" "$(_bold "$name") (active)"
    else
      printf "    %s\n" "$name"
    fi
    local sc=0 ac=0 rc=0 mc=0
    [ -d "$dir/skills" ] && sc=$(find "$dir/skills" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l)
    [ -d "$dir/agents" ] && ac=$(find "$dir/agents" -maxdepth 1 -name "*.md" 2>/dev/null | wc -l)
    [ -d "$dir/rules" ]  && rc=$(find "$dir/rules" -maxdepth 1 -name "*.md" 2>/dev/null | wc -l)
    [ -f "$dir/mcp.json" ] && command -v jq &>/dev/null && mc=$(jq '.mcpServers // {} | length' "$dir/mcp.json" 2>/dev/null || echo 0)
    printf "      skills:%-3s agents:%-3s rules:%-3s mcp:%s\n" "$sc" "$ac" "$rc" "$mc"
  done
  [ "$found" -eq 0 ] && echo "  (none — run: claude-profiles init <name>)"
  local ss=0 sm=0
  [ -d "$SHARED_DIR/skills" ] && ss=$(find "$SHARED_DIR/skills" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l)
  [ -f "$SHARED_DIR/mcp.json" ] && command -v jq &>/dev/null && sm=$(jq '.mcpServers // {} | length' "$SHARED_DIR/mcp.json" 2>/dev/null || echo 0)
  echo ""
  echo "  shared — skills:$ss  mcp:$sm"
}

cmd_validate() {
  local target="${1:-}"
  local errors=0

  _ok()   { echo "  $(_green "✓") $1"; }
  _fail() { echo "  $(_red "✗") $1${2:+ — $2}"; errors=$((errors + 1)); }
  _warn() { echo "  $(_yellow "~") $1"; }

  echo "$(_bold "Validating")"
  echo ""

  [ -d "$AGENTS_DIR" ]   && _ok "~/.agents/" || _fail "~/.agents/ missing"
  [ -d "$PROFILES_DIR" ] && _ok "profiles/"  || _fail "profiles/ missing"
  [ -d "$SHARED_DIR" ]   && _ok "shared/"    || _fail "shared/ missing"

  # jq availability
  if command -v jq &>/dev/null; then
    _ok "jq available (MCP support enabled)"
  else
    _warn "jq not found — MCP patching disabled"
  fi

  if [ -L "$AGENTS_DIR/current" ]; then
    if [ -d "$(readlink "$AGENTS_DIR/current")" ]; then
      _ok "current → $(_current_profile)"
    else
      _fail "current symlink" "broken: $(readlink "$AGENTS_DIR/current")"
    fi
  else
    _fail "current symlink" "not set"
  fi

  if [ -L "$CLAUDE_MD" ]; then
    local dest; dest="$(readlink "$CLAUDE_MD")"
    if [ -f "$dest" ]; then
      _ok "CLAUDE.md → $(basename "$(dirname "$dest")")"
    else
      _fail "CLAUDE.md symlink" "broken: $dest"
    fi
  elif [ -f "$CLAUDE_MD" ]; then
    _warn "CLAUDE.md is a regular file (not profile-managed)"
  else
    _warn "CLAUDE.md missing"
  fi

  # MCP state
  if [ -f "$MCP_STATE" ] && command -v jq &>/dev/null; then
    local mcp_profile; mcp_profile="$(jq -r '.profile // ""' "$MCP_STATE")"
    local mcp_count; mcp_count="$(jq '.managed_servers | length' "$MCP_STATE")"
    _ok "MCP state — profile: $mcp_profile, managed servers: $mcp_count"
  fi

  # Broken symlinks in managed claude dirs (only ones we own)
  echo ""
  local broken=0
  for artifact in "${ARTIFACTS[@]}"; do
    IFS=: read -r _pdir claude_subdir _type <<< "$artifact"
    local tdir="$CLAUDE_DIR/$claude_subdir"
    [ -d "$tdir" ] || continue
    while IFS= read -r -d '' link; do
      local dest; dest="$(readlink "$link")"
      [[ "$dest" == "$AGENTS_DIR/"* ]] || continue
      [ -e "$link" ] && continue
      echo "  $(_red "✗") broken: $claude_subdir/$(basename "$link")"
      broken=$((broken + 1)); errors=$((errors + 1))
    done < <(find "$tdir" -maxdepth 1 -type l -print0)
  done
  [ "$broken" -eq 0 ] && _ok "no broken managed symlinks in ~/.claude/"

  # Profile checks
  local profiles=()
  if [ -n "$target" ]; then
    _profile_exists "$target" || { echo "$(_red "Not found:") $target"; exit 1; }
    profiles=("$target")
  else
    for dir in "$PROFILES_DIR"/*/; do
      [ -d "$dir" ] && profiles+=("$(basename "$dir")")
    done
  fi

  for profile in "${profiles[@]}"; do
    echo ""
    echo "  $(_bold "$profile")"
    local pdir="$PROFILES_DIR/$profile"
    for subdir in agents rules skills output-styles workflows; do
      if [ -d "$pdir/$subdir" ]; then
        _ok "  $subdir/"
      else
        _warn "  $subdir/ (not created)"
      fi
    done
    if [ -f "$pdir/CLAUDE.md" ]; then
      _ok "  CLAUDE.md"
    else
      _warn "  CLAUDE.md (optional)"
    fi
    # mcp.json check
    if [ -f "$pdir/mcp.json" ]; then
      if command -v jq &>/dev/null; then
        if jq -e '.mcpServers' "$pdir/mcp.json" &>/dev/null; then
          local mc; mc="$(jq '.mcpServers | length' "$pdir/mcp.json")"
          _ok "  mcp.json ($mc server(s))"
        else
          _fail "  mcp.json" "missing mcpServers key"
        fi
      else
        _ok "  mcp.json (jq unavailable — skipping parse)"
      fi
    else
      _warn "  mcp.json (optional)"
    fi
    # Each skill folder must contain SKILL.md
    if [ -d "$pdir/skills" ]; then
      for skill_dir in "$pdir/skills"/*/; do
        [ -d "$skill_dir" ] || continue
        local sname; sname="$(basename "$skill_dir")"
        if [ ! -f "$skill_dir/SKILL.md" ]; then
          _fail "  skills/$sname/ missing SKILL.md"
        fi
      done
    fi
  done

  echo ""
  if [ "$errors" -eq 0 ]; then
    echo "$(_green "All checks passed")"
  else
    echo "$(_red "$errors error(s)")"
    exit 1
  fi
}

cmd_revert() {
  local current; current="$(_current_profile)"

  echo "$(_bold "Reverting claude-profiles")"
  echo ""

  # Remove all managed symlinks
  local removed=0
  for artifact in "${ARTIFACTS[@]}"; do
    IFS=: read -r _pdir claude_subdir _type <<< "$artifact"
    local tdir="$CLAUDE_DIR/$claude_subdir"
    [ -d "$tdir" ] || continue
    find "$tdir" -maxdepth 1 -type l | while read -r link; do
      local dest; dest="$(readlink "$link")"
      if [[ "$dest" == "$AGENTS_DIR/"* ]]; then
        rm "$link"
        echo "  - $claude_subdir/$(basename "$link")"
      fi
    done
  done

  # Restore CLAUDE.md from backup if we own the current symlink
  if [ -L "$CLAUDE_MD" ]; then
    local dest; dest="$(readlink "$CLAUDE_MD")"
    if [[ "$dest" == "$AGENTS_DIR/"* ]]; then
      rm "$CLAUDE_MD"
      if [ -f "${CLAUDE_MD}.bak" ]; then
        mv "${CLAUDE_MD}.bak" "$CLAUDE_MD"
        echo "  - CLAUDE.md symlink removed, restored from .bak"
      else
        echo "  - CLAUDE.md symlink removed (no .bak to restore)"
      fi
    fi
  fi

  # Remove managed MCP servers
  if [ -f "$MCP_STATE" ] && [ -f "$CLAUDE_JSON" ] && command -v jq &>/dev/null; then
    local prev_servers; prev_servers="$(jq '.managed_servers // []' "$MCP_STATE")"
    local count; count="$(jq 'length' <<< "$prev_servers")"
    if [ "$count" -gt 0 ]; then
      local tmp; tmp="$(mktemp)"
      jq --argjson prev "$prev_servers" \
        '.mcpServers = ((.mcpServers // {}) | with_entries(select(.key as $k | ($prev | index($k)) == null)))' \
        "$CLAUDE_JSON" > "$tmp" && mv "$tmp" "$CLAUDE_JSON"
      jq -r '.[]' <<< "$prev_servers" | while read -r name; do
        echo "  - mcp/$name"
      done
    fi
    rm "$MCP_STATE"
  fi

  # Remove current symlink
  [ -L "$AGENTS_DIR/current" ] && rm "$AGENTS_DIR/current"

  echo ""
  echo "$(_green "Reverted.") Claude Code restored to unmanaged state."
  echo "  ~/.agents/ left intact — profiles preserved"
  echo "  Run 'claude-profiles use <name>' to re-activate"
}

cmd_uninstall() {
  echo "$(_bold "Uninstall claude-profiles")"
  echo ""
  echo "This will:"
  echo "  1. Remove all managed symlinks from ~/.claude/"
  echo "  2. Remove managed MCP servers from ~/.claude.json"
  echo "  3. Restore CLAUDE.md from backup if available"
  echo "  4. Leave ~/.agents/ intact (your profiles are safe)"
  echo ""
  printf "Continue? [y/N] "
  read -r confirm
  [[ "$confirm" =~ ^[Yy]$ ]] || { echo "Aborted."; exit 0; }
  echo ""

  cmd_revert

  echo ""
  echo "Remove the binary:"
  echo "  sudo rm \"\$(which claude-profiles)\""
  echo ""
  echo "Remove profiles (optional, irreversible):"
  echo "  rm -rf ~/.agents"
}

cmd_help() {
  cat <<EOF
$(_bold "claude-profiles") — Claude Code agent profile switcher

$(_bold "Commands:")
  use <name>         switch to profile
  init <name>        scaffold new profile
  list               list profiles and active
  validate [name]    check integrity
  revert             remove profile from Claude config, restore clean state
  uninstall          revert + removal instructions

$(_bold "Profile structure  (~/.agents/profiles/<name>/):")
  agents/            → ~/.claude/agents/*.md
  rules/             → ~/.claude/rules/*.md (supports paths: frontmatter)
  skills/            → ~/.claude/skills/<skill>/ (folder with SKILL.md)
  output-styles/     → ~/.claude/output-styles/*.md
  workflows/         → ~/.claude/workflows/*.js
  CLAUDE.md          → ~/.claude/CLAUDE.md
  mcp.json           → ~/.claude.json mcpServers (requires jq)

$(_bold "Shared  (~/.agents/shared/):")
  Same structure + mcp.json. Always active. Profile wins on name conflict.

$(_bold "MCP notes:")
  Only servers defined in mcp.json are managed. Pre-existing servers in
  ~/.claude.json are never touched. State tracked in ~/.agents/.mcp-state.json.
  Takes effect on next Claude Code session start.

$(_bold "Env:")
  CLAUDE_PROFILES_DIR   (default: ~/.agents)
  CLAUDE_DIR            (default: ~/.claude)
EOF
}

case "${1:-help}" in
  use)       cmd_use "${2:-}" ;;
  init)      cmd_init "${2:-}" ;;
  list)      cmd_list ;;
  validate)  cmd_validate "${2:-}" ;;
  revert)    cmd_revert ;;
  uninstall) cmd_uninstall ;;
  help|--help|-h) cmd_help ;;
  *) echo "Unknown command: $1"; echo ""; cmd_help; exit 1 ;;
esac
